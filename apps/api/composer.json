{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "leverly/api",
    "type": "project",
    "description": "Leverly JSON API.",
    "keywords": ["leverly", "laravel", "api"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/fortify": "^1.36",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.3",
        "laravel/telescope": "^5.20",
        "laravel/tinker": "^3.0",
        "sentry/sentry-laravel": "^4.25"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7",
        "fakerphp/faker": "^1.23",
        "knuckleswtf/scribe": "^5.9",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@composer test:unit",
            "@composer test:api",
            "@composer test:integration"
        ],
        "test:unit": [
            "@php artisan config:clear --ansi",
            "@php artisan test --testsuite=Unit"
        ],
        "test:api": [
            "@php artisan config:clear --ansi",
            "@php artisan test --testsuite=API"
        ],
        "test:integration": [
            "@php artisan config:clear --ansi",
            "@php artisan test --testsuite=Integration"
        ],
        "test:coverage": [
            "@composer test:unit:coverage",
            "@composer test:api:coverage",
            "@composer test:integration:coverage"
        ],
        "test:unit:coverage": [
            "@php artisan config:clear --ansi",
            "@php -d xdebug.mode=off -d pcov.enabled=1 -d pcov.directory=app vendor/bin/phpunit --testsuite=Unit --coverage-clover=storage/logs/coverage-unit.xml",
            "@php artisan coverage:check storage/logs/coverage-unit.xml --min=0"
        ],
        "test:api:coverage": [
            "@php artisan config:clear --ansi",
            "@php -d xdebug.mode=off -d pcov.enabled=1 -d pcov.directory=app vendor/bin/phpunit --testsuite=API --coverage-clover=storage/logs/coverage-api.xml",
            "@php artisan coverage:check storage/logs/coverage-api.xml --min=0"
        ],
        "test:integration:coverage": [
            "@php artisan config:clear --ansi",
            "@php -d xdebug.mode=off -d pcov.enabled=1 -d pcov.directory=app vendor/bin/phpunit --testsuite=Integration --coverage-clover=storage/logs/coverage-integration.xml",
            "@php artisan coverage:check storage/logs/coverage-integration.xml --min=0"
        ],
        "format": [
            "pint"
        ],
        "format:test": [
            "pint --test"
        ],
        "openapi": [
            "@php artisan scribe:generate --no-interaction",
            "@php artisan leverly:openapi:sync-scribe"
        ],
        "ide-helper": [
            "@composer ide-helper:generate",
            "@composer ide-helper:meta",
            "@composer ide-helper:models"
        ],
        "ide-helper:generate": [
            "@php artisan ide-helper:generate"
        ],
        "ide-helper:meta": [
            "@php artisan ide-helper:meta"
        ],
        "ide-helper:models": [
            "@php artisan ide-helper:models --write-mixin --no-interaction"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
