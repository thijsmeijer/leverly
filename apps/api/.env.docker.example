APP_NAME=Leverly
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://api.leverly.local
FRONTEND_URL=http://web.leverly.local
CORS_ALLOWED_ORIGINS=http://web.leverly.local
SANCTUM_STATEFUL_DOMAINS=web.leverly.local,leverly.local,localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

TELESCOPE_ENABLED=true
TELESCOPE_PATH=telescope
TELESCOPE_PRUNE_HOURS=24

SENTRY_LARAVEL_DSN=null
SENTRY_RELEASE=null
SENTRY_ENVIRONMENT=local
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=null
SENTRY_PROFILES_SAMPLE_RATE=null
SENTRY_ENABLE_LOGS=false

DB_CONNECTION=pgsql
DB_HOST=leverly_postgres
DB_PORT=5432
DB_DATABASE=leverly
DB_USERNAME=leverly
DB_PASSWORD=leverly

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.leverly.local
SESSION_SAME_SITE=lax
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=leverly

REDIS_CLIENT=phpredis
REDIS_HOST=leverly_redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=leverly_mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@leverly.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
