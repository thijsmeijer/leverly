{
  "name": "@leverly/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "type-check": "node scripts/check-openapi-client.mjs && vue-tsc -b",
    "build": "node scripts/check-openapi-client.mjs && vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "node scripts/check-test-foundation.mjs && vitest run && node eslint-rules/architecture.test.mjs",
    "test:foundation": "node scripts/check-test-foundation.mjs",
    "test:unit": "vitest run",
    "test:architecture": "node eslint-rules/architecture.test.mjs",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test --grep @a11y",
    "test:a11y:foundation": "node scripts/check-accessibility-foundation.mjs",
    "api-client:generate": "node scripts/generate-openapi-types.mjs",
    "api-client:check": "node scripts/check-openapi-client.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:test": "prettier --check ."
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.100.1",
    "@vee-validate/zod": "^4.15.1",
    "chart.js": "^4.5.1",
    "dexie": "^4.4.2",
    "pinia": "^3.0.4",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.32",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.8",
    "@vue/tsconfig": "^0.9.1",
    "axe-core": "^4.11.3",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "0.7.3",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  }
}
